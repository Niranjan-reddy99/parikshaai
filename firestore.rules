rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: questions
    // Fields:
    //   - question: string (required)
    //   - options: map (required)
    //   - subject: string (required)
    //   - topic: string
    //   - subtopic: string
    //   - difficulty: string
    //   - concept: string
    //   - type: string
    //   - year: number (required)
    //   - exam: string (required)
    //   - createdAt: timestamp
    //
    // Collection: exams
    // Fields:
    //   - name: string (required)
    //   - year: number (required)
    //   - totalQuestions: number
    //   - processedAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['question', 'options', 'subject', 'year', 'exam']) &&
             data.question is string && data.question.size() > 0 && data.question.size() < 5000 &&
             data.options is map && data.options.keys().hasAll(['A', 'B', 'C', 'D']) &&
             data.subject is string &&
             data.year is number &&
             data.exam is string;
    }

    function isValidExam(data) {
      return data.keys().hasAll(['name', 'year']) &&
             data.name is string &&
             data.year is number;
    }

    // Rules
    match /questions/{questionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidQuestion(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidQuestion(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if false; // Prevention of data loss
    }

    match /exams/{examId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidExam(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidExam(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
