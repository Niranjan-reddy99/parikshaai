# UPSC AI Strategy Engine — Backend
# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
ADMIN_API_KEY=replace-with-a-long-random-secret
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional runtime config
CORS_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:4000,http://localhost:5173
UVICORN_RELOAD=false

# Optional model overrides
AI_MODEL_DEFAULT=publishers/google/models/gemini-2.0-flash
AI_MODEL_EXTRACTION=publishers/google/models/gemini-2.0-flash
AI_MODEL_EXTRACTION_REPAIR=publishers/google/models/gemini-2.5-flash
AI_MODEL_TAGGING=publishers/google/models/gemini-2.0-flash
AI_MODEL_EXPLANATION=publishers/google/models/gemini-2.5-flash
AI_MODEL_ANSWER=publishers/google/models/gemini-2.5-flash
