{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/__/auth/handler", "destination": "/api/firebase-auth-handler" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
